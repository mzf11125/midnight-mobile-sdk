<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.dedanzi.midnightmobilesdk">

    <!-- Biometric authentication permissions -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />

    <!-- Camera permission for QR scanning -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Internet permission for network calls -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Deep linking -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application>
        <!-- Deep link intent filters for midnight:// scheme -->
        <activity
            android:name=".DeepLinkActivity"
            android:launchMode="singleTask"
            android:noHistory="true">
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="midnight" />
            </intent-filter>
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="midnight-dapp" />
            </intent-filter>
        </activity>
    </application>
</manifest>
