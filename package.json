{
  "name": "@dedanzi/midnight-mobile-sdk",
  "version": "0.1.0",
  "description": "React Native SDK for Midnight Network - Mobile wallet, contracts, and DApp connectivity",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/src/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "MidnightMobileSDK.podspec"
  ],
  "scripts": {
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "prepare": "bob build",
    "release": "release-it",
    "example": "yarn --cwd example",
    "bootstrap": "yarn install && yarn example && yarn example prepare"
  },
  "keywords": [
    "midnight",
    "blockchain",
    "zero-knowledge",
    "react-native",
    "wallet",
    "mobile"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dedanzi/midnight-mobile-sdk.git"
  },
  "author": "dedanzi",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dedanzi/midnight-mobile-sdk/issues"
  },
  "homepage": "https://github.com/dedanzi/midnight-mobile-sdk#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@midnight-ntwrk/wallet-sdk-hd": "^2.12.0",
    "@midnight-ntwrk/wallet-sdk-facade": "^2.12.0",
    "@midnight-ntwrk/wallet-sdk-dust-wallet": "^2.12.0",
    "@midnight-ntwrk/midnight-js-contracts": "^1.3.0",
    "@midnight-ntwrk/http-client-proof-provider": "^1.4.0",
    "@midnight-ntwrk/indexer-public-data-provider": "^1.5.0",
    "@midnight-ntwrk/node-zk-config-provider": "^2.10.0",
    "@midnight-ntwrk/midnight-js-network-id": "^1.0.0",
    "@midnight-ntwrk/ledger-v7": "^2.12.0",
    "@midnight-ntwrk/zkp": "^2.12.0",
    "@apollo/client": "^3.11.8",
    "graphql": "^16.9.0",
    "graphql-ws": "^5.16.2",
    "bip39": "^3.1.0",
    "hdkey": "^2.1.0",
    "cls-rtracer": "^2.0.0",
    "eventemitter3": "^5.0.1",
    "uuid": "^11.0.3"
  },
  "peerDependencies": {
    "expo-local-authentication": ">=13.0.0",
    "expo-secure-store": ">=12.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.70.0",
    "react-native-quick-sqlite": ">=5.0.0"
  },
  "devDependencies": {
    "@react-native/eslint-config": "^0.75.4",
    "@release-it/conventional-changelog": "^9.0.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.9.0",
    "@types/bip39": "^3.0.0",
    "@types/hdkey": "^2.0.2",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.12",
    "@types/react-native": "^0.73.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "react": "^18.3.1",
    "react-native": "^0.75.4",
    "react-native-builder-bob": "^0.30.2",
    "release-it": "^17.10.1",
    "typescript": "^5.6.3"
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(@midnight-ntwrk|react-native|@react-native|@apollo|graphql)/)"
    ]
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.json"
        }
      ]
    ]
  }
}
